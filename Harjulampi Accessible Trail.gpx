
                    <gpx version="1.1" creator="https://etiainen.fi/en/tracks/harjulampi-accessible-trail-885" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" xmlns="http://www.topografix.com/GPX/1/1">
                        <metadata>
                            <link href="https://etiainen.fi/en/tracks/harjulampi-accessible-trail-885">
                              <text><![CDATA[Harjulammen esteetön reitti]]></text>
