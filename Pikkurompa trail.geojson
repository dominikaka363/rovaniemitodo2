"features": [
{ "type": "Feature", "properties": { "name": "Pikkurompanpolku", "cmt": null, "desc": "<p>Pikkurompanpolku sijaitsee Vikajärvellä, noin 20,7 kilometriä Rovaniemen keskustasta Sodankylään päin. Pikkurompanpolku kuuluu Napapiirin retkeilyalueeseen. Napapiirin retkeilyalue on ympärivuotiseen retkeilyyn soveltuva erämainen luontokohde. Maiseman erityispiirteinä ovat karut peräpohjalaiset vaarat, rannattomat ja vetiset aapasuot sekä Raudanjoki komeine koskineen ja rehevine rantametsineen. Retkeilyalueella on monipuolinen reitistö taukopaikkoineen, joka tarjoaa kaikenikäisille hyviä retkeilykohteita ja –mahdollisuuksia. Sijaintinsa ansiosta alueelle on helppo tulla kaikkina vuodenaikoina.\n</p>\n<p>\n</p>\n<p>Pikkurompanpolku tutustuttaa retkeilijän Sortovaaran lähes luonnontilaisiin vanhoihin metsiin. Reitin varrella on myös suo-osuuksia, jotka ylitetään pitkospuita pitkin. Rengasreitti ja reitin alun janareitin edestakainen pituus yhteensä noin 4,5 kilometriä. Polku on vaativuusluokitukseltaan keskivaativa. Jos reitin kulkee vain reitin läntistä haaraa Sortovaaran kodalle ja samaa reittiä takaisin, se on vaativuudeltaan helppo, sillä keskivaativaa osuutta on vain Sortovaaran ympäristö. Reitti soveltuu patikoinnin lisäksi talvella lumikenkäilyyn.\n</p>\n<p>\n</p>\n<p>Reitin varrella Sortovaarassa on kota, jossa retkeilijät voivat tulistella. Lisäksi on liiteri ja kuivakäymälä. Kodan lähistöllä on lähde.\n</p>\n<p>\n</p>\n<p>Rovaniemen keskustasta Sodankyläntietä noin 22,1 km, josta oikealle risteyksen vieressä olevalle Makialammen pysäköintialueelle, josta Pikkurompanpolkua opasteiden mukaan. Reitin alussa Sodankyläntie alitetaan tunnelia pitkin. Napapiirin retkeilyalueelle pääsee myös Sodankyläntiellä liikennöivillä julkisilla kulkuvälineillä kohtuullisen lähelle reittejä. Vaattunkikönkään pysäköintialueelle on Sodankyläntieltä matkaa noin 2,1 km Vaattunkikönkääntietä pitkin. Vikakönkään pysäköintialue on Sodankyläntien läheisyydessä.\n</p>\n<p>\n</p>\n<p><a href=\"http://www.luontoon.fi/napapiiri/reitit\" target=\"_blank\">Lähteet, lisätietoja</a></p>", "src": null, "link1_href": null, "link1_text": null, "link1_type": null, "link2_href": null, "link2_text": null, "link2_type": null, "number": null, "type": "track" }, "geometry": { "type": "MultiLineString", "coordinates": [ [ [ 26.09347653, 66.61402589, 0.0 ], [ 26.09353497, 66.61413268, 0.0 ], [ 26.09357961, 66.6141924, 0.0 ], [ 26.09366602, 66.61424939, 0.0 ], [ 26.09377162, 66.61427035, 0.0 ], [ 26.09398142, 66.61431959, 0.0 ], [ 26.09412968, 66.61440646, 0.0 ], [ 26.09425249, 66.6144245, 0.0 ], [ 26.09438027, 66.61442745, 0.0 ], [ 26.09471386, 66.61440631, 0.0 ], [ 26.09485334, 66.61440934, 0.0 ], [ 26.09497306, 66.61443646, 0.0 ], [ 26.09506313, 66.61446606, 0.0 ], [ 26.09515293, 66.61450609, 0.0 ], [ 26.09527956, 66.61452103, 0.0 ], [ 26.09543528, 66.61454976, 0.0 ], [ 26.0956766, 66.61459993, 0.0 ], [ 26.09595322, 66.61466776, 0.0 ], [ 26.09610818, 66.61471926, 0.0 ], [ 26.09620431, 66.61483543, 0.0 ], [ 26.09620444, 66.61492675, 0.0 ], [ 26.09615091, 66.6150832, 0.0 ], [ 26.09615304, 66.61514254, 0.0 ], [ 26.09615788, 66.61527731, 0.0 ], [ 26.09622458, 66.61541185, 0.0 ], [ 26.09634124, 66.61555526, 0.0 ], [ 26.09638008, 66.6156668, 0.0 ], [ 26.09637925, 66.6157534, 0.0 ], [ 26.09639498, 66.61580156, 0.0 ], [ 26.09632354, 66.61584228, 0.0 ], [ 26.09584841, 66.61589328, 0.0 ], [ 26.09550595, 66.61594306, 0.0 ], [ 26.09538461, 66.61596567, 0.0 ], [ 26.09523427, 66.61599516, 0.0 ], [ 26.09483486, 66.61608796, 0.0 ], [ 26.09462757, 66.61612935, 0.0 ], [ 26.09449508, 66.61617353, 0.0 ], [ 26.09437945, 66.6161962, 0.0 ], [ 26.09419406, 66.61623671, 0.0 ], [ 26.09390855, 66.61630358, 0.0 ], [ 26.09379264, 66.61639808, 0.0 ], [ 26.0937564, 66.61649126, 0.0 ], [ 26.09359009, 66.61660924, 0.0 ], [ 26.09350956, 66.61665212, 0.0 ], [ 26.09346272, 66.61669485, 0.0 ], [ 26.09346977, 66.61674541, 0.0 ], [ 26.09357733, 66.6168366, 0.0 ], [ 26.09357518, 66.61689501, 0.0 ], [ 26.09360795,